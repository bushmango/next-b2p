{
  "name": "next-b2p",
  "version": "1.0.0",
  "scripts": {
    "1": "node scripts/concurrently.js",
    "2": "yarn css-watch",
    "s": "yarn 1",
    "sidecar": "yarn barrel-rider-sidecar --remove --watch --src components lib common apiLib",
    "css-watch": "yarn typed-scss-modules  \"**/*.module.scss\" --ignore \"**/node_modules\" --watch",
    "css": "yarn typed-scss-modules  \"**/*.module.scss\" --ignore \"**/node_modules\"",
    "dev": "next -p 3001",
    "build": "next build",
    "start": "next start",
    "kill-port": "node scripts/kill-port-3001.js",
    "type-check": "next typegen && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:dump": "node scripts/pg-dump-backup.js",
    "db:restore": "node scripts/pg-restore-backup.js",
    "db:grant-restore-access": "node scripts/pg-grant-restore-access.js",
    "db:verify-restore": "node scripts/pg-verify-restore.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "1.2.36",
    "@fortawesome/free-regular-svg-icons": "5.15.4",
    "@fortawesome/free-solid-svg-icons": "5.15.4",
    "@fortawesome/react-fontawesome": "0.1.16",
    "@types/lodash": "4.14.176",
    "@types/ramda": "0.27.47",
    "adm-zip": "^0.5.12",
    "fast-random": "^2.0.4",
    "google-books-search": "^0.3.1",
    "knex": "^3.2.10",
    "lodash": "4.17.21",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.14",
    "next": "16",
    "pg": "^8.21.0",
    "ramda": "0.27.1",
    "ramda-adjunct": "2.35.0",
    "react": "19",
    "react-dom": "19",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "barrel-rider-sidecar": "1.1.8",
    "concurrently": "6.3.0",
    "console-title": "^1.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "husky": "7.0.4",
    "prettier": "2.4.1",
    "pretty-quick": "3.1.1",
    "rimraf": "^3.0.2",
    "sass": "^1.101.0",
    "typed-scss-modules": "8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "UNLICENSED"
}
